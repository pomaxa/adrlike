{% extends 'base.html.twig' %}
{% block title %}New product · Admin{% endblock %}

{% block body %}
<div class="container" style="max-width: 480px;">

  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="{{ path('app_admin_product_index') }}">Products</a></li>
      <li class="breadcrumb-item active">New product</li>
    </ol>
  </nav>

  <h4 class="fw-semibold mb-4"><i class="bi bi-plus-lg me-2 text-primary"></i>New product</h4>

  {{ form_start(form) }}

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-4">
      <div class="mb-1">
        <label class="form-label fw-semibold small" for="{{ form.name.vars.id }}">Product name</label>
        <div class="input-group {% if form.name.vars.errors|length %}has-validation{% endif %}">
          <span class="input-group-text bg-white text-muted"><i class="bi bi-box-seam"></i></span>
          {{ form_widget(form.name, {attr: {class: 'form-control' ~ (form.name.vars.errors|length ? ' is-invalid' : '')}}) }}
          {% for error in form.name.vars.errors %}
            <div class="invalid-feedback">{{ error.message }}</div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2 mb-5">
    <button class="btn btn-primary px-4" type="submit"><i class="bi bi-check-lg me-1"></i>Create</button>
    <a class="btn btn-outline-secondary" href="{{ path('app_admin_product_index') }}">Cancel</a>
  </div>

  {{ form_end(form) }}
</div>
{% endblock %}
