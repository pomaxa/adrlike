{% extends 'base.html.twig' %}

{% block title %}Audit log{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0"><i class="bi bi-clock-history"></i> Audit log</h1>
    <span class="text-muted small">{{ total }} event{{ total == 1 ? '' : 's' }}</span>
</div>

<form method="get" class="card p-3 bg-white mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-2">
            <label class="form-label small mb-1">From</label>
            <input type="date" name="from" value="{{ filters.from }}" class="form-control form-control-sm">
        </div>
        <div class="col-md-2">
            <label class="form-label small mb-1">To</label>
            <input type="date" name="to" value="{{ filters.to }}" class="form-control form-control-sm">
        </div>
        <div class="col-md-2">
            <label class="form-label small mb-1">Actor (name/email)</label>
            <input type="text" name="actor" value="{{ filters.actor }}" class="form-control form-control-sm" placeholder="who">
        </div>
        <div class="col-md-2">
            <label class="form-label small mb-1">Field</label>
            <input type="text" name="field" value="{{ filters.field }}" class="form-control form-control-sm" placeholder="e.g. followUpDate">
        </div>
        <div class="col-md-3">
            <label class="form-label small mb-1">Search value</label>
            <input type="text" name="q" value="{{ filters.q }}" class="form-control form-control-sm" placeholder="search in values / change desc.">
        </div>
        <div class="col-md-1 d-grid">
            <button class="btn btn-sm btn-primary">Filter</button>
        </div>
    </div>
    {% if filters.from or filters.to or filters.actor or filters.field or filters.q %}
        <div class="mt-2"><a class="small" href="{{ path('app_audit_index') }}">Clear filters</a></div>
    {% endif %}
</form>

<div class="card bg-white">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width: 160px">When</th>
                    <th style="width: 180px">Actor</th>
                    <th style="width: 180px">Field</th>
                    <th>Change</th>
                    <th style="width: 140px">Decision</th>
                </tr>
            </thead>
            <tbody>
                {% for h in entries %}
                    <tr>
                        <td class="text-nowrap small text-muted">{{ h.changedAt|date('Y-m-d H:i') }}</td>
                        <td>
                            {% if h.changedBy %}
                                {{ h.changedBy.fullName }}
                            {% else %}
                                <span class="text-muted">system / CLI</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if h.isCreation %}
                                <span class="badge bg-success">Created</span>
                            {% else %}
                                <strong>{{ decision_history_label(h.fieldName) }}</strong>
                                <div class="text-muted small"><code>{{ h.fieldName }}</code></div>
                            {% endif %}
                        </td>
                        <td>
                            {% if h.isCreation %}
                                <span class="text-muted">Initial change: </span>{{ h.newValue|audit_truncate(160, '…') ?: '—' }}
                            {% else %}
                                <div class="small">
                                    <span class="text-muted">from</span>
                                    <span class="audit-old">{{ h.oldValue is null ? '∅' : h.oldValue|audit_truncate(120, '…') }}</span>
                                </div>
                                <div class="small">
                                    <span class="text-muted">to</span>
                                    <span class="audit-new">{{ h.newValue is null ? '∅' : h.newValue|audit_truncate(120, '…') }}</span>
                                </div>
                            {% endif %}
                        </td>
                        <td>
                            <a href="{{ path('app_decision_show', {id: h.decision.id}) }}" class="small">
                                {{ h.decision.decidedAt|date('Y-m-d') }}
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="5" class="text-center text-muted py-4">No audit events match those filters.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% if totalPages > 1 %}
    <nav class="mt-3" aria-label="Audit pagination">
        <ul class="pagination pagination-sm">
            {% set qs = filters|filter(v => v is not null and v != '') %}
            {% if page > 1 %}
                <li class="page-item"><a class="page-link" href="{{ path('app_audit_index', qs|merge({page: page - 1})) }}">← Prev</a></li>
            {% endif %}
            <li class="page-item disabled"><span class="page-link">Page {{ page }} of {{ totalPages }}</span></li>
            {% if page < totalPages %}
                <li class="page-item"><a class="page-link" href="{{ path('app_audit_index', qs|merge({page: page + 1})) }}">Next →</a></li>
            {% endif %}
        </ul>
    </nav>
{% endif %}
{% endblock %}

{% block stylesheets %}
<style>
    .audit-old { color: #b02a37; text-decoration: line-through; }
    .audit-new { color: #146c43; }
</style>
{% endblock %}
